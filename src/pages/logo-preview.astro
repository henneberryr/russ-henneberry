---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Logo Preview" description="Logo concepts for Russ Henneberry">
  <section class="py-20 px-6 bg-[--color-bg]">
    <div class="max-w-5xl mx-auto">
      <p class="section-label mb-4 text-center">Logo Concepts</p>
      <h1 class="text-3xl md:text-4xl text-center text-[--color-text] mb-4">Five Directions</h1>
      <div class="gold-rule gold-rule-sm mx-auto mb-16"></div>

      <!-- Each logo shown on light and dark backgrounds -->
      <div class="space-y-20">

        <!-- LOGO 1: The Editorial -->
        <div>
          <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-6">01 — The Editorial</p>
          <p class="text-sm text-[--color-secondary] mb-8 max-w-lg">Classic serif with generous letter-spacing. Feels like a byline in a premium magazine. Quiet authority.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <span style="font-family: 'DM Serif Display', serif; font-size: 1.75rem; letter-spacing: 0.06em; color: #1A1A1A;">
                Russ Henneberry
              </span>
            </div>
            <div class="bg-[--color-primary] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <span style="font-family: 'DM Serif Display', serif; font-size: 1.75rem; letter-spacing: 0.06em; color: #FFFFFF;">
                Russ Henneberry
              </span>
            </div>
          </div>
        </div>

        <!-- LOGO 2: The Architect -->
        <div>
          <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-6">02 — The Architect</p>
          <p class="text-sm text-[--color-secondary] mb-8 max-w-lg">Sans-serif, all caps, wide tracking. Structured and precise. The gold dot is the signature mark -- a period that says "built, not borrowed."</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <span style="font-family: 'DM Sans', sans-serif; font-size: 1.25rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #1A1A1A;">
                Russ Henneberry<span style="color: #C27D2B;">.</span>
              </span>
            </div>
            <div class="bg-[--color-primary] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <span style="font-family: 'DM Sans', sans-serif; font-size: 1.25rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #FFFFFF;">
                Russ Henneberry<span style="color: #C27D2B;">.</span>
              </span>
            </div>
          </div>
        </div>

        <!-- LOGO 3: The Stacked -->
        <div>
          <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-6">03 — The Stacked</p>
          <p class="text-sm text-[--color-secondary] mb-8 max-w-lg">First name light, last name bold. Stacked vertically with a gold rule between. Creates a monogram feel without an actual monogram. Compact. Memorable.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-10 flex items-center justify-center min-h-[140px]">
              <div style="text-align: center; line-height: 1.1;">
                <span style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; letter-spacing: 0.25em; text-transform: uppercase; color: #475569; display: block;">Russ</span>
                <div style="width: 24px; height: 2px; background: #C27D2B; margin: 6px auto;"></div>
                <span style="font-family: 'DM Serif Display', serif; font-size: 1.5rem; letter-spacing: 0.04em; color: #1A1A1A; display: block;">Henneberry</span>
              </div>
            </div>
            <div class="bg-[--color-primary] rounded-[--radius] p-10 flex items-center justify-center min-h-[140px]">
              <div style="text-align: center; line-height: 1.1;">
                <span style="font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 400; letter-spacing: 0.25em; text-transform: uppercase; color: rgba(255,255,255,0.5); display: block;">Russ</span>
                <div style="width: 24px; height: 2px; background: #C27D2B; margin: 6px auto;"></div>
                <span style="font-family: 'DM Serif Display', serif; font-size: 1.5rem; letter-spacing: 0.04em; color: #FFFFFF; display: block;">Henneberry</span>
              </div>
            </div>
          </div>
        </div>

        <!-- LOGO 4: The Bold Serif -->
        <div>
          <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-6">04 — The Bold Serif</p>
          <p class="text-sm text-[--color-secondary] mb-8 max-w-lg">Oversized initials "RH" in serif with full name beside in small caps. A mark that works at any size. The initials become an icon; the name provides context.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-family: 'DM Serif Display', serif; font-size: 2.75rem; line-height: 1; color: #1E3A5F;">RH</span>
                <div style="width: 1px; height: 36px; background: #E8E2DA;"></div>
                <div style="line-height: 1.3;">
                  <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: #1A1A1A; display: block;">Russ</span>
                  <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: #1A1A1A; display: block;">Henneberry</span>
                </div>
              </div>
            </div>
            <div class="bg-[--color-primary] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <div style="display: flex; align-items: center; gap: 12px;">
                <span style="font-family: 'DM Serif Display', serif; font-size: 2.75rem; line-height: 1; color: #C27D2B;">RH</span>
                <div style="width: 1px; height: 36px; background: rgba(255,255,255,0.15);"></div>
                <div style="line-height: 1.3;">
                  <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.8); display: block;">Russ</span>
                  <span style="font-family: 'DM Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.8); display: block;">Henneberry</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- LOGO 5: The Signature -->
        <div>
          <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-6">05 — The Signature</p>
          <p class="text-sm text-[--color-secondary] mb-8 max-w-lg">Mixed weight in a single line. "Russ" in light sans-serif, "Henneberry" in bold serif. The contrast creates visual interest and hierarchy. Personal but polished.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <span style="font-family: 'DM Sans', sans-serif; font-size: 1.625rem; font-weight: 300; color: #475569;">Russ</span>
                <span style="font-family: 'DM Serif Display', serif; font-size: 1.75rem; color: #1A1A1A;">Henneberry</span>
              </div>
            </div>
            <div class="bg-[--color-primary] rounded-[--radius] p-10 flex items-center justify-center min-h-[120px]">
              <div style="display: flex; align-items: baseline; gap: 8px;">
                <span style="font-family: 'DM Sans', sans-serif; font-size: 1.625rem; font-weight: 300; color: rgba(255,255,255,0.5);">Russ</span>
                <span style="font-family: 'DM Serif Display', serif; font-size: 1.75rem; color: #FFFFFF;">Henneberry</span>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- AI-GENERATED LOGOS -->
      <div class="mt-32">
        <p class="section-label mb-4 text-center">AI-Generated Concepts</p>
        <h2 class="text-3xl md:text-4xl text-center text-[--color-text] mb-4">Gemini Image Variations</h2>
        <div class="gold-rule gold-rule-sm mx-auto mb-16"></div>

        <div class="space-y-16">
          <div>
            <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-4">01 — Editorial Serif</p>
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-8 flex items-center justify-center">
              <img src="/images/logo-concepts/logo-editorial-serif.png" alt="Editorial Serif Logo" class="max-h-32 object-contain" />
            </div>
          </div>

          <div>
            <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-4">02 — Modern Sans + Gold Dot</p>
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-8 flex items-center justify-center">
              <img src="/images/logo-concepts/logo-modern-sans.png" alt="Modern Sans Logo" class="max-h-32 object-contain" />
            </div>
          </div>

          <div>
            <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-4">03 — Stacked Mixed Weight</p>
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-8 flex items-center justify-center">
              <img src="/images/logo-concepts/logo-stacked-mixed.png" alt="Stacked Mixed Logo" class="max-h-32 object-contain" />
            </div>
          </div>

          <div>
            <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-4">04 — RH Monogram</p>
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-8 flex items-center justify-center">
              <img src="/images/logo-concepts/logo-monogram-rh.png" alt="RH Monogram Logo" class="max-h-32 object-contain" />
            </div>
          </div>

          <div>
            <p class="text-sm text-[--color-muted] uppercase tracking-widest mb-4">05 — Signature Contrast</p>
            <div class="bg-white border border-[--color-border] rounded-[--radius] p-8 flex items-center justify-center">
              <img src="/images/logo-concepts/logo-signature-contrast.png" alt="Signature Contrast Logo" class="max-h-32 object-contain" />
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
