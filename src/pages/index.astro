---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CredentialsBar from '../components/CredentialsBar.astro';
import ProblemStatement from '../components/ProblemStatement.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import StatsBar from '../components/StatsBar.astro';
import Testimonial from '../components/Testimonial.astro';
import CtaBanner from '../components/CtaBanner.astro';
---

<BaseLayout
  title="Home"
  description="Russ Henneberry is an AI Marketing Consultant, Trainer, and Keynote Speaker helping teams build AI marketing systems that actually work."
>
  <!-- 1. HERO -->
  <Hero
    variant="split"
    headline="I Help Teams Build AI Marketing Systems That Actually Work"
    subheadline="Co-author of Digital Marketing for Dummies. Helping companies move from AI curiosity to AI execution."
    buttonText="Schedule a Call"
    buttonUrl="https://calendly.com/russhenneberry/custom-workshops"
    secondaryButtonText="Watch Free Training"
    secondaryButtonUrl="https://www.youtube.com/@jointheCLICK"
    image="/images/russ-hero-nobg.png"
    imageAlt="Russ Henneberry"
  />

  <!-- 2. CREDENTIALS BAR -->
  <CredentialsBar
    items={[
      "Co-author of Digital Marketing for Dummies",
      "1,000+ Teams Trained",
      "Keynote Speaker at Kajabi, Smart Marketer & Traffic & Conversion"
    ]}
  />

  <!-- 3. THE PROBLEM -->
  <ProblemStatement
    statement="Most teams have tried AI. They've played with chatbots, generated some blog posts, maybe automated a few tasks. But the gap between experimenting with AI and actually running your marketing on AI is massive."
    body="<p>I've spent two decades in digital marketing and co-wrote the book on it. When AI agents arrived and changed everything, I built the systems and training programs that help teams make the leap from 'this is interesting' to 'this is how we work now.'</p>"
    closer="That's the gap I close."
  />

  <!-- 4. SERVICES -->
  <FeatureGrid
    subheadline="What I Do"
    headline="Three Ways We Work Together"
    variant="numbered-editorial"
    items={[
      {
        title: "Keynote Speaking",
        description: "High-energy presentations on AI marketing transformation for conferences, summits, and company events. Audiences from 50 to 5,000+."
      },
      {
        title: "Team Workshops",
        description: "Hands-on sessions where your team builds real AI marketing workflows. They leave with working systems, not just inspiration."
      },
      {
        title: "Custom AI Agents",
        description: "Bespoke AI marketing systems built for your business. Configured with your offers, audience, voice, and workflows. Ready to produce on day one."
      }
    ]}
  />

  <!-- 5. STATS -->
  <StatsBar
    background="dark"
    stats={[
      { number: "20+", label: "Years in Digital Marketing" },
      { number: "1,000+", label: "Teams Trained" },
      { number: "#1", label: "Best-Selling Author" },
      { number: "50+", label: "Keynotes Delivered" }
    ]}
  />

  <!-- 6. TESTIMONIALS -->
  <Testimonial
    variant="featured-plus-grid"
    background="light"
    testimonials={[
      {
        quote: "Russ taught us how to think for ourselves and build any AI solution we needed. In just two months, Russ completely transformed our marketing team.",
        author: "Lauryn Snelson",
        title: "COO, Zipify"
      },
      {
        quote: "Russ is always on the cutting edge, first doing the work, then teaching it in a way that actually clicks. He's become one of the most trusted voices I know.",
        author: "Molly Pittman",
        title: "CEO, Smart Marketer"
      },
      {
        quote: "This program helped our team build a practical AI system we could actually use day-to-day. The results were immediate.",
        author: "Anney Perrine",
        title: "SVP of Growth, PALM Health"
      }
    ]}
  />

  <!-- 7. FINAL CTA -->
  <CtaBanner
    variant="architect"
    label="Next Step"
    headline="Let's Build Your AI Marketing System"
    body="Book a free discovery call. 30 minutes. No pitch. Just clarity."
    buttonText="Schedule a Call"
    buttonUrl="https://calendly.com/russhenneberry/custom-workshops"
    subButtonText="Free 30-minute consultation"
  />
</BaseLayout>
