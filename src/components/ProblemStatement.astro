---
interface Props {
  statement: string;
  body?: string;
  closer?: string;
}

const { statement, body, closer } = Astro.props;
---

<section class="bg-[--color-primary] relative overflow-hidden">
  <div class="max-w-3xl mx-auto px-6 lg:px-12 py-24 md:py-32 lg:py-40 text-center">
    <p class="text-2xl md:text-3xl lg:text-[2.25rem] leading-[1.3] text-white mb-10 animate-fade-in-up" style="font-family: var(--font-heading);">
      {statement}
    </p>
    {body && (
      <div class="text-base md:text-lg text-white/60 leading-relaxed max-w-2xl mx-auto mb-10 space-y-4 animate-fade-in-up animation-delay-100" set:html={body} />
    )}
    {closer && (
      <p class="text-xl md:text-2xl text-white font-medium animate-fade-in-up animation-delay-200" style="font-family: var(--font-heading);">
        {closer}
      </p>
    )}
    <div class="gold-rule gold-rule-md mx-auto mt-10 animate-fade-in-up animation-delay-300"></div>
  </div>
</section>
