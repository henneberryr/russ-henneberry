---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<section class="bg-white relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-[--color-accent] opacity-20"></div>
  <div class="absolute bottom-0 left-0 right-0 h-px bg-[--color-accent] opacity-20"></div>
  <div class="max-w-6xl mx-auto px-6 lg:px-12 py-5">
    <div class="flex flex-wrap justify-center items-center gap-x-3 gap-y-2 text-center">
      {items.map((item, i) => (
        <>
          <span class="text-xs md:text-sm font-medium uppercase tracking-[0.12em] text-[--color-secondary]">
            {item}
          </span>
          {i < items.length - 1 && (
            <span class="text-[--color-accent] opacity-40 text-xs">&#9670;</span>
          )}
        </>
      ))}
    </div>
  </div>
</section>
