---
interface Props {
  businessName: string;
  tagline?: string;
  navLinks?: { text: string; url: string }[];
  socialLinks?: { platform: string; url: string }[];
  email?: string;
}

const { businessName, tagline, navLinks = [], socialLinks = [], email } = Astro.props;
const year = new Date().getFullYear();

const socialIcons: Record<string, string> = {
  linkedin: '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>',
  youtube: '<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="var(--color-bg)" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>',
};
---

<footer class="bg-[--color-primary] text-white/90">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="font-[--font-heading] text-2xl text-white tracking-tight">
          {businessName}
        </a>
        {tagline && (
          <p class="mt-3 text-white/60 text-sm max-w-sm leading-relaxed">
            {tagline}
          </p>
        )}
        {email && (
          <a href={`mailto:${email}`} class="mt-4 inline-block text-sm text-white/60 hover:text-[--color-accent] transition-colors">
            {email}
          </a>
        )}
      </div>

      <!-- Links & Social -->
      <div class="flex flex-col md:items-end gap-8">
        {navLinks.length > 0 && (
          <nav class="flex gap-6">
            {navLinks.map((link) => (
              <a href={link.url} class="text-sm text-white/70 hover:text-white transition-colors">
                {link.text}
              </a>
            ))}
          </nav>
        )}
        {socialLinks.length > 0 && (
          <div class="flex gap-4">
            {socialLinks.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-white/50 hover:text-[--color-accent] transition-colors"
                aria-label={link.platform}
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" set:html={socialIcons[link.platform] || ''} />
              </a>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <p class="text-sm text-white/40">
        &copy; {year} {businessName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
