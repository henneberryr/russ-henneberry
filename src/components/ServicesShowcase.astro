---
interface ServiceItem {
  title: string;
  description: string;
  details?: string[];
  price?: string;
  image?: string;
  imageAlt?: string;
  buttonText?: string;
  buttonUrl?: string;
}

interface Props {
  headline?: string;
  subheadline?: string;
  items: ServiceItem[];
}

const { headline, subheadline, items } = Astro.props;
---

<section class="py-24 md:py-32 px-6 bg-[--color-bg]">
  <div class="max-w-6xl mx-auto">
    {(headline || subheadline) && (
      <div class="text-center mb-16">
        {headline && (
          <h2 class="text-3xl md:text-4xl text-[--color-text] mb-4">{headline}</h2>
        )}
        {subheadline && (
          <p class="text-lg text-[--color-secondary] max-w-2xl mx-auto">{subheadline}</p>
        )}
      </div>
    )}

    <div class="space-y-8">
      {items.map((item, i) => (
        <div class={`group bg-white border border-[--color-border] rounded-[--radius] overflow-hidden animate-fade-in-up hover:shadow-xl hover:border-[--color-primary]/20 transition-all duration-300`} style={`animation-delay: ${i * 0.1}s`}>
          <div class={`grid grid-cols-1 ${item.image ? 'lg:grid-cols-3' : ''} gap-0`}>
            {item.image && (
              <div class="lg:col-span-1">
                <img
                  src={item.image}
                  alt={item.imageAlt || item.title}
                  class="w-full h-64 lg:h-full object-cover"
                  loading="lazy"
                />
              </div>
            )}
            <div class={`p-8 md:p-10 ${item.image ? 'lg:col-span-2' : ''}`}>
              <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                <h3 class="text-2xl text-[--color-text]">{item.title}</h3>
                {item.price && (
                  <span class="inline-flex items-center px-3 py-1 bg-[--color-accent]/10 text-[--color-accent] text-sm font-semibold rounded-full">
                    {item.price}
                  </span>
                )}
              </div>
              <p class="text-[--color-secondary] leading-relaxed mb-6">{item.description}</p>
              {item.details && item.details.length > 0 && (
                <ul class="grid grid-cols-1 md:grid-cols-2 gap-2 mb-6">
                  {item.details.map((detail) => (
                    <li class="flex items-start gap-2 text-sm text-[--color-secondary]">
                      <svg class="w-5 h-5 text-[--color-accent] flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      {detail}
                    </li>
                  ))}
                </ul>
              )}
              {item.buttonText && item.buttonUrl && (
                <a
                  href={item.buttonUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center px-6 py-3 bg-[--color-cta] text-white font-semibold rounded-[--radius] hover:bg-[--color-cta-hover] transition-all duration-200 shadow-sm"
                >
                  {item.buttonText}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
